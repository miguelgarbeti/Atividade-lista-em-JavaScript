const prompt = require('prompt-sync')();

console.log("--- Troca de Valores entre Variáveis ---");

// Importante: prompt sempre lê TEXTO. 
// Usamos Number() para converter, igual ao (int) ou (float) no C.
let num1 = Number(prompt("Digite o primeiro número: "));
let num2 = Number(prompt("Digite o segundo número: "));

console.log(`Valores antes da troca: ${num1} e ${num2}`);

// Troca de valores
let temp = num1;
num1 = num2;
num2 = temp;

console.log(`Valores após a troca: ${num1} e ${num2}`);